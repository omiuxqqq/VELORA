export default function Orders(){const orders=['#10258 Оплачен','#10259 В сборке','#10260 Передан в доставку'];return <main className='min-h-screen bg-night p-5'><div className='max-w-5xl mx-auto'><Link href='/admin' className='text-emeraldAccent'>← Админка</Link><h1 className='text-5xl font-black mt-4'>Заказы</h1><div className='glass rounded-3xl p-6 mt-6'>{orders.map(o=><div key={o} className='flex justify-between py-4 border-b border-emeraldAccent/10'><b>{o}</b><select className='max-w-xs'><option>Оплачен</option><option>В сборке</option><option>Передан в доставку</option><option>Доставлен</option></select></div>)}</div></div></main>}
